#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
ROOT="${CODEX_HOME:-$DEFAULT_ROOT}"
SCREEN_NAME="codex-qq-bridge"
PORT="${CODEX_QQ_BRIDGE_PORT:-8765}"
BRIDGE="${ROOT}/bin/codex_qq_bridge.mjs"
CODEX_BIN_PATTERN="${CODEX_BIN:-codex}"

screen -S "$SCREEN_NAME" -X quit >/dev/null 2>&1 || true
bridge_pids="$(pgrep -f "$BRIDGE" || true)"
if [[ -n "$bridge_pids" ]]; then
  pkill -TERM -P "$bridge_pids" >/dev/null 2>&1 || true
  kill $bridge_pids >/dev/null 2>&1 || true
fi
pkill -TERM -f "${CODEX_BIN_PATTERN} .*exec .* -C ${ROOT}" >/dev/null 2>&1 || true
pids="$(lsof -tiTCP:"$PORT" -sTCP:LISTEN || true)"
if [[ -n "$pids" ]]; then
  kill $pids
fi
echo "Stopped Codex QQ bridge screen session: ${SCREEN_NAME}"
