#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
ROOT="${CODEX_HOME:-$DEFAULT_ROOT}"
SERVER_ROOT="${CODEX_SERVER_ROOT:-${HOME}/.codex/servers}"
NODE="${NODE:-node}"
BRIDGE="${ROOT}/bin/codex_qq_bridge.mjs"
TOKEN_FILE="${CODEX_QQ_TOKEN_FILE:-${SERVER_ROOT}/astrbot/data/codex_qq_bridge.token}"
LOG_DIR="${CODEX_QQ_LOG_DIR:-${ROOT}/logs/codex-qq-bridge}"
LOG_FILE="${LOG_DIR}/codex_qq_bridge_node.log"
SCREEN_NAME="codex-qq-bridge"
HOST="${CODEX_QQ_BRIDGE_HOST:-0.0.0.0}"
PORT="${CODEX_QQ_BRIDGE_PORT:-8765}"

mkdir -p "$LOG_DIR" "$(dirname "$TOKEN_FILE")"

if [[ ! -f "$TOKEN_FILE" ]]; then
  umask 077
  if command -v openssl >/dev/null 2>&1; then
    openssl rand -hex 32 > "$TOKEN_FILE"
  else
    "$NODE" -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))" > "$TOKEN_FILE"
  fi
fi

if screen -ls | grep -Fq "${SCREEN_NAME}"; then
  echo "Codex QQ bridge already running in screen session: ${SCREEN_NAME}"
  exit 0
fi

if lsof -tiTCP:"$PORT" -sTCP:LISTEN >/dev/null 2>&1; then
  echo "Port ${PORT} is already in use. Stop the old bridge first with bin/codex-qq-bridge-down."
  exit 1
fi

: > "$LOG_FILE"
export CODEX_QQ_BRIDGE_LOG="$LOG_FILE"
screen -dmS "$SCREEN_NAME" /bin/bash -lc 'exec "$@" >>"$CODEX_QQ_BRIDGE_LOG" 2>&1' _ "$NODE" "$BRIDGE" --host "$HOST" --port "$PORT"
echo "Codex QQ bridge started with Node in screen session: ${SCREEN_NAME}, http://${HOST}:${PORT}"
echo "Logs: ${ROOT}/bin/codex-qq-bridge-logs"
