#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
ROOT="${CODEX_HOME:-$DEFAULT_ROOT}"
LOG_DIR="${CODEX_QQ_LOG_DIR:-${ROOT}/logs/codex-qq-bridge}"
LOG_FILE="${LOG_DIR}/codex_qq_bridge_node.log"
LEGACY_LOG_FILE="${ROOT}/bin/logs/codex_qq_bridge_node.log"

if [[ ! -f "$LOG_FILE" && -f "$LEGACY_LOG_FILE" ]]; then
  LOG_FILE="$LEGACY_LOG_FILE"
fi

if [[ ! -f "$LOG_FILE" ]]; then
  echo "No Codex QQ bridge log yet. Start it with ${ROOT}/bin/codex-qq-bridge-up."
  exit 1
fi

tail -f "$LOG_FILE"
